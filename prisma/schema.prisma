// ─── AI Resume Analyzer — Prisma Schema (Phase 10 Performance) ─────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  resumes   Resume[]
  analyses  Analysis[]
  subscription Subscription?
  usageRecords UsageRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Subscription {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  plan                       String    @default("free")
  status                     String    @default("inactive")
  provider                   String    @default("razorpay")
  razorpaySubscriptionId      String?   @unique
  razorpayPlanId             String?
  razorpayCustomerId         String?
  currentPeriodStart         DateTime?
  currentPeriodEnd           DateTime?
  cancelAtPeriodEnd          Boolean   @default(false)
  cancelledAt                DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, plan])
  @@index([razorpayPlanId])
  @@map("subscriptions")
}

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  kind        String
  count       Int      @default(0)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, periodStart])
  @@index([userId, periodStart, periodEnd])
  @@map("usage_records")
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventId     String   @unique
  eventType   String
  payload     Json?
  processedAt DateTime @default(now())

  @@index([provider, eventType])
  @@map("webhook_events")
}

// ─── Resume ────────────────────────────────────────────────────────
model Resume {
  id         String     @id @default(cuid())
  userId     String
  title      String
  fileName   String
  fileUrl    String
  fileKey    String?
  fileType   String     // pdf, docx
  fileSize   Int
  parsedData Json?
  rawText    String?
  analyses   Analysis[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite index for dashboard queries (find resumes by user, newest first)
  @@index([userId, createdAt])
  // Index for file lookups
  @@index([userId, fileType])
  // Index for title search
  @@index([userId, title])
  @@map("resumes")
}

// ─── Analysis ──────────────────────────────────────────────────────
model Analysis {
  id             String     @id @default(cuid())
  resumeId       String
  userId         String
  jobDescription String?
  status         String     @default("pending") // pending, processing, completed, failed
  type           String     @default("full")    // full, ats_only, ai_only
  durationMs     Int?
  atsReport      AtsReport?
  aiFeedback     AiFeedback?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite index for dashboard stats query (completed analyses by user)
  @@index([userId, status, createdAt])
  // Composite index for checking in-progress analyses
  @@index([resumeId, userId, type, status])
  // Composite index for reports queries
  @@index([resumeId, type, status, createdAt])
  // Index for finding analyses with reports
  @@index([status, type, createdAt])
  @@map("analyses")
}

// ─── ATS Report ────────────────────────────────────────────────────
model AtsReport {
  id              String   @id @default(cuid())
  analysisId      String   @unique
  score           Int
  keywordMatch    Int
  matchedKeywords Json?
  missingKeywords Json?
  readability     Int?
  formattingScore Int?
  formatting      Json?
  sectionScore    Json?
  suggestions     Json?
  rawAnalysis     String?  @db.Text
  createdAt       DateTime @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Index for dashboard score distribution queries
  @@index([score])
  // Index for trend queries over time
  @@index([createdAt, score])
  @@map("ats_reports")
}

// ─── AI Feedback ───────────────────────────────────────────────────
model AiFeedback {
  id              String   @id @default(cuid())
  analysisId      String   @unique
  strengths       Json?
  weaknesses      Json?
  improvements    Json?
  careerAdvice    String?  @db.Text
  summary         String?  @db.Text
  overallRating   Int?
  bulletPoints    Json?
  grammarIssues   Json?
  skillGaps       Json?
  rawResponse     String?  @db.Text
  modelUsed       String?
  tokensUsed      Int?
  createdAt       DateTime @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Index for average rating calculations
  @@index([overallRating])
  @@map("ai_feedback")
}
